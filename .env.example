# Product Discovery Terminal local environment
#
# Copy this file to .env and fill values locally. .env is ignored by git.

# Etsy Open API v3
# Keep disabled while app approval is pending.
ETSY_API_ENABLED=false
ETSY_API_KEYSTRING=your_etsy_keystring
ETSY_SHARED_SECRET=your_etsy_shared_secret
ETSY_API_BASE_URL=https://openapi.etsy.com/v3/application
ETSY_REQUEST_TIMEOUT_SECONDS=15

# Alibaba.com Open API
# Keep disabled while app/API access is pending.
ALIBABA_API_ENABLED=false
ALIBABA_APP_KEY=your_alibaba_app_key
ALIBABA_APP_SECRET=your_alibaba_app_secret
ALIBABA_ACCESS_TOKEN=your_alibaba_access_token
# Fill this after Alibaba approval confirms the product/supplier search API route.
ALIBABA_PRODUCT_SEARCH_URL=
ALIBABA_REQUEST_TIMEOUT_SECONDS=20

# Cost ceiling defaults
# Replace these as real Amazon Product Fees and quote data become available.
COST_CEILING_MARKETPLACE_FEE_RATE=0.15
COST_CEILING_FULFILLMENT_FEE_RATE=0.13
COST_CEILING_FULFILLMENT_FEE_FLOOR=3.25
COST_CEILING_SUPPLIER_FREIGHT_FALLBACK_PER_UNIT=1.00
COST_CEILING_PACKAGING_COST_PER_UNIT=0.65
COST_CEILING_INBOUND_COST_PER_UNIT=0.75
COST_CEILING_STORAGE_COST_PER_UNIT=0.35
COST_CEILING_RETURN_ALLOWANCE_RATE=0.04
COST_CEILING_AD_ALLOWANCE_RATE=0.12
COST_CEILING_TARGET_PROFIT_RATE=0.20
