# Product Discovery Terminal local environment
#
# Copy this file to .env and fill values locally. .env is ignored by git.

# Etsy Open API v3
# Keep disabled while app approval is pending.
ETSY_API_ENABLED=false
ETSY_API_KEYSTRING=your_etsy_keystring
ETSY_SHARED_SECRET=your_etsy_shared_secret
ETSY_API_BASE_URL=https://openapi.etsy.com/v3/application
ETSY_REQUEST_TIMEOUT_SECONDS=15

