# Product Discovery Terminal local environment
#
# Copy this file to .env and fill values locally. .env is ignored by git.

APP_ENV=development
ALLOW_PUBLIC_UNAUTHENTICATED=false
PUBLIC_APP_URL=
COMPLIANCE_DOCS_PATH=../compliance

# Etsy Open API v3
# Keep disabled while app approval is pending.
ETSY_API_ENABLED=false
ETSY_API_KEYSTRING=your_etsy_keystring
ETSY_SHARED_SECRET=your_etsy_shared_secret
ETSY_API_BASE_URL=https://openapi.etsy.com/v3/application
ETSY_REQUEST_TIMEOUT_SECONDS=15

# Alibaba.com Open API
# Keep disabled while app/API access is pending.
ALIBABA_API_ENABLED=false
ALIBABA_APP_KEY=your_alibaba_app_key
ALIBABA_APP_SECRET=your_alibaba_app_secret
ALIBABA_ACCESS_TOKEN=your_alibaba_access_token
# Fill this after Alibaba approval confirms the product/supplier search API route.
ALIBABA_PRODUCT_SEARCH_URL=
ALIBABA_REQUEST_TIMEOUT_SECONDS=20

# Amazon Selling Partner API
# Start with sandbox while validating credentials; switch to production after self-authorization.
AMAZON_SP_API_ENABLED=false
AMAZON_SP_API_ENV=sandbox
AMAZON_SP_API_ENDPOINT=https://sandbox.sellingpartnerapi-na.amazon.com
AMAZON_SP_API_ENDPOINT_SANDBOX=https://sandbox.sellingpartnerapi-na.amazon.com
AMAZON_SP_API_ENDPOINT_PRODUCTION=https://sellingpartnerapi-na.amazon.com
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_LWA_CLIENT_ID=replace_me
AMAZON_LWA_CLIENT_SECRET=replace_me
AMAZON_LWA_REFRESH_TOKEN=replace_me
AMAZON_LWA_TOKEN_URL=https://api.amazon.com/auth/o2/token
AMAZON_USER_AGENT=ProductDiscoveryTerminal/0.1.0 (Language=Python)
AMAZON_REQUEST_TIMEOUT_SECONDS=20
AMAZON_REQUEST_MAX_ATTEMPTS=3
AMAZON_REQUEST_BACKOFF_SECONDS=0.5
AMAZON_CATALOG_SEARCH_LIMIT=10
AMAZON_FEES_DEFAULT_MODELED_PRICE=24.99
AMAZON_REFRESH_CATALOG_LIMIT=10
AMAZON_REFRESH_PRICING_LIMIT=10
AMAZON_REFRESH_FEE_LIMIT=5
AMAZON_PRICING_CACHE_TTL_HOURS=24
AMAZON_PRICING_REQUEST_INTERVAL_SECONDS=1.1
AMAZON_FEES_CACHE_TTL_HOURS=24
AMAZON_FEES_REQUEST_INTERVAL_SECONDS=1.1
STORE_RAW_AMAZON_PAYLOADS=false
RAW_PAYLOAD_RETENTION_DAYS=7

# Cost ceiling defaults
# Replace these as real Amazon Product Fees and quote data become available.
COST_CEILING_MARKETPLACE_FEE_RATE=0.15
COST_CEILING_FULFILLMENT_FEE_RATE=0.13
COST_CEILING_FULFILLMENT_FEE_FLOOR=3.25
COST_CEILING_SUPPLIER_FREIGHT_FALLBACK_PER_UNIT=1.00
COST_CEILING_PACKAGING_COST_PER_UNIT=0.65
COST_CEILING_INBOUND_COST_PER_UNIT=0.75
COST_CEILING_STORAGE_COST_PER_UNIT=0.35
COST_CEILING_RETURN_ALLOWANCE_RATE=0.04
COST_CEILING_AD_ALLOWANCE_RATE=0.12
COST_CEILING_TARGET_PROFIT_RATE=0.20
